# ─── General ───────────────────────────────────────────────────────
APP_NAME=Secretary AI
ENVIRONMENT=dev
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Europe/London
# Language: "ru" for Russian, "en" for English. Controls system prompts,
# greeting, TTS voice, STT model, and template replies.
LANGUAGE=ru

# ─── OpenAI / LLM ─────────────────────────────────────────────────
# Supports direct OpenAI or any OpenAI-compatible gateway
# (e.g. Pydantic AI Gateway, vLLM, Ollama).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
# Optional: use a different (faster/cheaper) model for /api/v1/chat
OPENAI_CHAT_MODEL=
OPENAI_TIMEOUT_SECONDS=30

# Agent reasoning tokens
AGENT_MAX_TOKENS=160
AGENT_HISTORY_TURNS=4
AGENT_LIVE_MAX_TOKENS=72
AGENT_LIVE_HISTORY_TURNS=1
AGENT_LIVE_TEMPERATURE=0.1
AGENT_LIVE_TIMEOUT_SECONDS=4.0

# Chat (text dialogue via API)
CHAT_MAX_TOKENS=64
CHAT_TEMPERATURE=0.15

# ─── Gemini Live (audio-to-audio voice calls) ─────────────────────
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Voices: Puck, Charon, Kore, Fenrir, Aoede, Zephyr
GEMINI_LIVE_VOICE=Zephyr
GEMINI_LIVE_ENABLED=true

# ─── Telegram MTProto ─────────────────────────────────────────────
# Get credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=.telegram/secretary
TELEGRAM_AUTO_ANSWER_INBOUND=true
TELEGRAM_AUTO_START_LIVE_AGENT=true
TELEGRAM_AUTO_START_LIVE_SPEAK_RESPONSE=true
TELEGRAM_AUTO_START_SCAN_SECONDS=2.0
TELEGRAM_AUDIO_ROOT=.telegram/audio

# Greeting behaviour
ASSISTANT_AUTO_GREET_ON_CONNECT=true
# Leave empty to use language-default greeting
ASSISTANT_GREETING_MESSAGE=

# Live loop tuning
TELEGRAM_LIVE_POLL_SECONDS=0.3
TELEGRAM_LIVE_TTS_COOLDOWN_SECONDS=0.3
TELEGRAM_LIVE_DEBUG=true
TELEGRAM_LIVE_DEBUG_LOG_PATH=.telegram/logs/live_debug.jsonl
TELEGRAM_STREAM_PLAY_TIMEOUT_SECONDS=2.5
TEMPLATE_REPLY_COOLDOWN_SECONDS=6.0

# ─── TTS (used for reminder calls and non-Gemini replies) ─────────
# Providers: "edge_tts" (cloud, Microsoft Neural voices) or "silero" (local, Russian-native)
TTS_ENABLED=true
TTS_PROVIDER=silero
# Leave empty to auto-select based on LANGUAGE
TTS_VOICE=
TTS_RATE=+0%
TTS_VOLUME=+0%

# Silero TTS (Russian-native, open-source, local inference — no API key needed)
# Model: v5_5_ru (latest Russian), v3_en (English)
# Speakers (Russian): aidar, baya, kseniya, xenia, eugene
# Sample rates: 8000, 24000, 48000
TTS_SILERO_MODEL_ID=v5_5_ru
TTS_SILERO_SPEAKER=xenia
TTS_SILERO_SAMPLE_RATE=48000
TTS_SILERO_DEVICE=cpu

# ─── STT (speech-to-text, used when not in Gemini Live mode) ──────
STT_ENABLED=true
STT_PROVIDER=faster_whisper
# Leave empty to auto-select based on LANGUAGE
STT_MODEL=
STT_LANGUAGE=
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_MIN_CHARS=4
STT_RECENT_ONLY=true
STT_TAIL_SECONDS=2.0
STT_MIN_NEW_BYTES=1200

# ─── Google Calendar ──────────────────────────────────────────────
CALENDAR_ENABLED=true
CALENDAR_TIMEZONE=Europe/London
CALENDAR_ID=

# OAuth 2.0 (recommended for multi-user)
# Create at: https://console.cloud.google.com/apis/credentials
# Type: Web Application
# Redirect URI: http://localhost:8000/api/v1/calendar/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Service Account (alternative — single-user/self-hosted)
CALENDAR_SERVICE_ACCOUNT_JSON=.telegram/service_account.json

# Calendar worker
CALENDAR_CACHE_PATH=.telegram/cache/calendar_events.json
CALENDAR_QUEUE_PATH=.telegram/cache/calendar_queue.json
CALENDAR_WORKER_ENABLED=true
CALENDAR_WORKER_POLL_SECONDS=2.0
CALENDAR_WORKER_BATCH_SIZE=4
CALENDAR_PLANNER_MAX_TOKENS=140
CALENDAR_REFRESH_INTERVAL_SECONDS=300

# ─── Reminders ────────────────────────────────────────────────────
REMINDER_ENABLED=true
# @username or numeric user ID for reminder calls
REMINDER_TARGET_USER=
REMINDER_LEAD_MINUTES=60
REMINDER_SCAN_HORIZON_HOURS=48
REMINDER_STATE_PATH=.telegram/cache/reminder_state.json

# ─── Wake-word engine ─────────────────────────────────────────────
WAKE_WORD_ENABLED=true
WAKE_WORD_PREFIX=secretary
WAKE_WORD_ALIASES=
WAKE_WORD_REQUIRE_PREFIX=false
WAKE_WORD_CONFIG_PATH=.telegram/cache/wake_word_actions.json

# ─── Booking search ──────────────────────────────────────────────
BOOKING_DEFAULT_LOCATION=London
BOOKING_MAX_RESULTS=5

# ─── Audio Cleanup ────────────────────────────────────────────────
AUDIO_CLEANUP_ENABLED=true
AUDIO_CLEANUP_INTERVAL_SECONDS=600
AUDIO_CLEANUP_MAX_AGE_HOURS=24
AUDIO_CLEANUP_KEEP_RECENT_FILES=60

# ─── External Services (optional) ────────────────────────────────
# Tavily web search API key (https://tavily.com)
TAVILY_API_KEY=
# Google Maps Distance Matrix API key
GOOGLE_MAPS_API_KEY=
