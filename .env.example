APP_NAME=Secretary AI
ENVIRONMENT=dev
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Europe/London
# Language: "ru" for Russian, "en" for English. Controls system prompts,
# greeting, and template replies.
LANGUAGE=ru

# Z.AI GLM (text chat / agent reasoning)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.1
# Optional: use a faster chat model for /api/v1/chat (voice dialogue uses this).
# Example value: glm-4.5-air
ZAI_CHAT_MODEL=
ZAI_TIMEOUT_SECONDS=30
AGENT_MAX_TOKENS=160
AGENT_HISTORY_TURNS=4
CHAT_MAX_TOKENS=96
CHAT_TEMPERATURE=0.25

# Gemini Live (audio-to-audio voice loop on Telegram calls)
# Gemini 3.1 Flash Live handles all voice calls natively.
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr
GEMINI_LIVE_ENABLED=true

# Google Maps ETA (Distance Matrix API)
GOOGLE_MAPS_API_KEY=

# Telegram MTProto user account
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=.telegram/secretary
TELEGRAM_AUTO_ANSWER_INBOUND=true
TELEGRAM_AUTO_START_LIVE_AGENT=true
TELEGRAM_AUTO_START_LIVE_SPEAK_RESPONSE=true
TELEGRAM_AUTO_START_SCAN_SECONDS=2.0
TELEGRAM_AUDIO_ROOT=.telegram/audio
ASSISTANT_AUTO_GREET_ON_CONNECT=true
ASSISTANT_GREETING_MESSAGE=Здравствуйте, это ваш ИИ-секретарь. Чем могу помочь?

# TTS voice (used only for reminder announcement calls)
TTS_ENABLED=true
TTS_PROVIDER=edge_tts
TTS_VOICE=ru-RU-DmitryNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# Google Calendar
CALENDAR_ENABLED=true
CALENDAR_TIMEZONE=Europe/London
CALENDAR_ID=
CALENDAR_SERVICE_ACCOUNT_JSON=.telegram/service_account.json
CALENDAR_CACHE_PATH=.telegram/cache/calendar_events.json
CALENDAR_QUEUE_PATH=.telegram/cache/calendar_queue.json
CALENDAR_WORKER_ENABLED=true
CALENDAR_WORKER_POLL_SECONDS=2.0
CALENDAR_WORKER_BATCH_SIZE=4
CALENDAR_PLANNER_MAX_TOKENS=140
CALENDAR_REFRESH_INTERVAL_SECONDS=300

# Event reminder calls
REMINDER_ENABLED=true
# Optional fallback target (@username or numeric id string) when call target is unknown.
REMINDER_TARGET_USER=
REMINDER_LEAD_MINUTES=60
REMINDER_SCAN_HORIZON_HOURS=48
REMINDER_STATE_PATH=.telegram/cache/reminder_state.json

# Wake-word engine — configurable voice command triggers
# When enabled, phrases like "Secretary, find a restaurant" are detected
# and routed directly to the appropriate action handler.
WAKE_WORD_ENABLED=true
# The primary wake-word prefix. Set to your bot's name or "secretary".
WAKE_WORD_PREFIX=secretary
# Comma-separated aliases for the wake-word prefix (e.g. "hey secretary,sec")
WAKE_WORD_ALIASES=
# If true, the wake-word prefix must be spoken for action routing.
# If false, action phrases alone are enough (e.g. "find a restaurant").
WAKE_WORD_REQUIRE_PREFIX=false
# Path to optional custom wake-word action definitions (JSON).
WAKE_WORD_CONFIG_PATH=.telegram/cache/wake_word_actions.json

# Booking search defaults
BOOKING_DEFAULT_LOCATION=London
BOOKING_MAX_RESULTS=5

# Web search (Tavily) — used by booking search
TAVILY_API_KEY=

# Generated audio cleanup
AUDIO_CLEANUP_ENABLED=true
AUDIO_CLEANUP_INTERVAL_SECONDS=600
AUDIO_CLEANUP_MAX_AGE_HOURS=24
AUDIO_CLEANUP_KEEP_RECENT_FILES=60
